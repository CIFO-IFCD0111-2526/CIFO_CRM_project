<div class="page-header">
  <div>
    <a href="/cursos" class="back-link">
      <i class="fa-solid fa-arrow-left"></i> Tornar al llistat
    </a>
    <h1 class="page-title">
      <%= curso.nombre %>
    </h1>
    <p class="page-subtitle">
      <span class="badge">
        <%= curso.codigo %>
      </span>
    </p>
  </div>

  <div class="acciones">
    <button  class="btn btn-secundario" id="btn-curso-editar" >Editar</button>
    <!-- <a href="/cursos/<%= curso.id %>/editar" class="btn btn-secundario" id="btn-curso-editar" >Editar</a> -->
    <button  class="btn btn-secundario hidden" id="btn-curso-guardar"  type="submit">Guardar</button>
    <button  class="btn btn-secundario hidden" id="btn-curso-cancelar-edit" >Cancelar</button>
    <button type="button" class="btn btn-danger btn-eliminar" data-id="<%= curso.id %>" data-nombre="<%= curso.nombre %>">Eliminar</button>
  </div>
</div>

<div id="form-ple" class="detalle-grid ">

  <!-- Datos del curso -->
  <section class="detalle-card">
    <h2 class="detalle-card-title">Dades del curs</h2>
    <dl class="detalle-list">
      <div class="detalle-item">
        <dt>Codi</dt>
        <dd>
          <%= curso.codigo || '—' %>
        </dd>
      </div>
      <div class="detalle-item">
        <dt>Data inici</dt>
        <dd>
          <%= curso.fecha_inicio || '—' %>
        </dd>
      </div>
      <div class="detalle-item">
        <dt>Requisits</dt>
        <dd>
          <%= curso.requisitos || '—' %>
        </dd>
      </div>
      <div class="detalle-item">
        <dt>Data fi</dt>
        <dd>
          <%= curso.fecha_fin || '—' %>
        </dd>
      </div>
    </dl>
  </section>

  <!-- UFs -->
  <section class="detalle-card">
    <h2 class="detalle-card-title">UFs</h2>
    <% if (curso.Ufs && curso.Ufs.length> 0) { %>
      <ul class="detalle-cursos">
        <% curso.Ufs.forEach(uf=> { %>
          <li>
            <span class="curso-nombre">
              <%= uf.nombre %>
            </span>
          </li>
          <% }) %>
      </ul>
      <% } else { %>
        <p class="detalle-empty">No hi ha UFs associades.</p>
        <% } %>
  </section>

  <!-- Professors -->
  <section class="detalle-card">
    <h2 class="detalle-card-title">Professors</h2>
    <% if (curso.Profesors && curso.Profesors.length> 0) { %>
      <ul class="detalle-cursos">
        <% curso.Profesors.forEach(prof=> { %>
          <li>
            <span class="curso-nombre">
              <%= prof.nombre %>
                <%= prof.apellidos %>
            </span>
          </li>
          <% }) %>
      </ul>
      <% } else { %>
        <p class="detalle-empty">No hi ha professors associats.</p>
        <% } %>
  </section>

  <!-- Alumnes -->
  <section class="detalle-card detalle-full">
    <h2 class="detalle-card-title">Alumnes</h2>
    <% if (curso.Alumnos && curso.Alumnos.length> 0) { %>
      <ul class="detalle-cursos">
        <% curso.Alumnos.forEach(al=> { %>
          <li>
            <span class="curso-nombre">
              <%= al.nombre %>
                <%= al.apellidos %>
            </span>
          </li>
          <% }) %>
      </ul>
      <% } else { %>
        <p class="detalle-empty">No hi ha alumnes matriculats.</p>
        <% } %>
  </section>

</div>
<!-- ---FORM EDITABLE --- ---FORM EDITABLE --- ---FORM EDITABLE --- ---FORM EDITABLE --- ---FORM EDITABLE --- ---FORM EDITABLE --- ---FORM EDITABLE --- -->
<div id="form-editable" class="detalle-grid hidden ">

  <!-- Datos del curso -->
  <section class="detalle-card">
    <h2 class="detalle-card-title">Dades del curs</h2>
    <dl class="detalle-list">
      <div class="detalle-item">
        <dt>Codi</dt>
        <input value="<%= curso.codigo || '—' %>">
      </div>
      <div class="detalle-item">
        <dt>Data inici</dt>
        <input 
          type="date" 
          value="<%= curso.fecha_inicio ? new Date(curso.fecha_inicio).toLocaleDateString('en-CA') : '' %>"
        >
      </div>
      <div class="detalle-item">
        <dt>Requisits</dt>
        <!-- 
        <input value="<%= curso.requisitos || '—' %>"> 
        <select id="RegCursoRequisitos" name="requisitos">
          <option value="">Selecciona nivell</option>
          <option value="0">Sense estudis</option>
          <option value="1">Primària</option>
          <option value="2">Secundària</option>
          <option value="4">FP Grau Mitjà</option>
          <option value="5">Batxillerat</option>
          <option value="6">FP Grau Superior</option>
        </select>
        -->
        <select id="RegCursoRequisitos" name="requisitos">
          <option value="">Selecciona nivell</option>
          <option value="0" <%=curso.dataValues.requisitos==0 ? "selected" : "" %>>Sense estudis</option>
          <option value="1" <%=curso.dataValues.requisitos==1 ? "selected" : "" %>>Primària</option>
          <option value="2" <%=curso.dataValues.requisitos==2 ? "selected" : "" %>>Secundària</option>
          <option value="4" <%=curso.dataValues.requisitos==4 ? "selected" : "" %>>FP Grau Mitjà</option>
          <option value="5" <%=curso.dataValues.requisitos==5 ? "selected" : "" %>>Batxillerat</option>
          <option value="6" <%=curso.dataValues.requisitos==6 ? "selected" : "" %>>FP Grau Superior</option>
        </select>

      </div>
      <div class="detalle-item">
        <dt>Data fi</dt>
        <input 
          type="date" 
          value="<%= curso.fecha_fin ? new Date(curso.fecha_fin).toLocaleDateString('en-CA') : '' %>"
        >
      </div>
    </dl>
  </section>

  <!-- UFs -->
  <section class="detalle-card">
