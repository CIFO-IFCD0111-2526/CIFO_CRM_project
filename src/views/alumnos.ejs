<div class="page-header">
  <div>
    <h1 class="page-title">Alumnes</h1>
    <p class="page-subtitle">Llistat d'alumnes registrats al centre</p>
  </div>
  <a href="/alumnos/nuevo" class="btn btn-primario">Nou alumne</a>
</div>
<div class="buscador-alumnos">
  <input
    type="text"
    id="busquedaAlumno"
    placeholder="Cercar alumne..."
    autocomplete="off"
  />
  <div id="loader" class="caja-der">
      <div id="dropdownResultados" class="dropdown hidden"></div>
  </div>
</div>
<% if (alumnos && alumnos.length > 0) { %>
  <div class="tabla-container">
    <table id="alumnosTable">
      <thead>
        <tr>
          <th>Cognoms, Nom</th>
          <th>DNI</th>
          <th>Email</th>
          <th>Telèfon</th>
          <th>Nivell d'estudis</th>
          <th>Tipus</th>
          <th>Data d'alta</th>
          <th class="col-accions">Accions</th>
        </tr>
      </thead>
      <tbody>
        <% alumnos.forEach(alumno => { %>
          <tr>
            <td>
              <a class="alumno-nombre" href="/alumnos/<%= alumno.id %>">
                <%= alumno.apellidos %>, <%= alumno.nombre %>
              </a>
            </td>
            <td><%= alumno.dni || '—' %></td>
            <td><%= alumno.email || '—' %></td>
            <td><%= alumno.telefono || '—' %></td>
            <td><%= alumno.nivel_estudios || '—' %></td>
            <td>
              <span class="badge badge-<%= alumno.tipo %>">
                <% if (alumno.tipo === 'actual') { %>Actual<% } %>
                <% if (alumno.tipo === 'antiguo') { %>Antic<% } %>
                <% if (alumno.tipo === 'futuro') { %>Futur<% } %>
              </span>
            </td>
            <td class="col-fecha">
              <%= alumno.createdAt ? new Date(alumno.createdAt).toLocaleDateString('ca-ES', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '—' %>
            </td>
            <td class="col-accions">
              <div class="acciones">
                <a href="/alumnos/<%= alumno.id %>/editar" class="btn btn-secundario btn-sm">Editar</a>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="empty-state">
    <p>No hi ha alumnes registrats.</p>
    <a href="/alumnos/nuevo" class="btn btn-primario">Crear el primer alumne</a>
  </div>
<% } %>