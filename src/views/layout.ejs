<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %> | CIFO La Violeta</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
    <% if (locals.css) { %>
        <link rel="stylesheet" href="/css/<%= css %>">
    <% } %>
    <script src="/js/main.js" defer></script>
    <% if (locals.js) { %>
        <script src="/js/<%= js %>" defer></script>
    <% } %>
</head>
<body>
    <div class="app-container">
        <% if (usuario) { %>
            <nav>
                <div class="nav-logo">
                    <img src="/images/logo.webp" alt="CIFO La Violeta">
                </div>

                <div class="nav-links">
                    <a href="/dashboard" class="<% if (paginaActual === 'dashboard') { %>active<% } %>">
                        <i class="fa-solid fa-gauge"></i> Dashboard
                    </a>
                    <a href="/alumnos" class="<% if (paginaActual === 'alumnos') { %>active<% } %>">
                        <i class="fa-solid fa-user-graduate"></i> Alumnos
                    </a>
                    <a href="/cursos" class="<% if (paginaActual === 'cursos') { %>active<% } %>">
                        <i class="fa-solid fa-book"></i> Cursos
                    </a>
                    <a href="/ufs" class="<% if (paginaActual === 'ufs') { %>active<% } %>">
                        <i class="fa-solid fa-layer-group"></i> UF's
                    </a>
                    <a href="/profesores" class="<% if (paginaActual === 'profesores') { %>active<% } %>">
                        <i class="fa-solid fa-chalkboard-user"></i> Profesores
                    </a>
                    <% if (usuario.nivel_acceso === 'admin') { %>
                        <a href="/usuarios" class="<% if (paginaActual === 'usuarios') { %>active<% } %>">
                            <i class="fa-solid fa-gear"></i> Administración
                        </a>
                    <% } %>
                </div>

                <div class="nav-bottom">
                    <a href="/ayuda"><i class="fa-solid fa-circle-question"></i> Ayuda</a>
                    <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Cerrar sesión</a>
                </div>
            </nav>
        <% } %>

        <main class="<% if (usuario) { %>with-nav<% } %>">
            <%- body %>
        </main>
    </div>
</body>
</html>