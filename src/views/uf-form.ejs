<% var styles='<link rel="stylesheet" href="/css/forms.css">' %>

<div class="form-container">
    <div class="form-card">

        <a href="/ufs" class="back-link">
            <i class="fa-solid fa-arrow-left"></i> Tornar al llistat
        </a>

        <h1 class="form-title">
            <%= uf && uf.id ? "Editar UF" : "Crear UF" %>
        </h1>

        <p class="form-subtitle">
            <%= uf && uf.id ? "Modifica les dades de la UF" : "Introdueix les dades de la nova UF" %>
        </p>

        <form id="ufForm" class="form-grid" 
              method="POST" 
              action="<%= uf && uf.id ? '/ufs/' + uf.id + '?_method=PUT' : '/ufs' %>">

            <!-- Codi -->
            <div class="form-group">
                <label>
                    Codi
                    <input type="text" name="codigo" 
                           value="<%= uf ? uf.codigo : '' %>" required />
                </label>

                <% if (errores && errores.codigo) { %>
                    <div class="error"><%= errores.codigo %></div>
                <% } %>
            </div>

            <!-- Nom -->
            <div class="form-group">
                <label>
                    Nom
                    <input type="text" name="nombre" 
                           value="<%= uf ? uf.nombre : '' %>" required />
                </label>

                <% if (errores && errores.nombre) { %>
                    <div class="error"><%= errores.nombre %></div>
                <% } %>
            </div>

            <!-- Hores -->
            <div class="form-group">
                <label>
                    Hores
                    <input type="number" name="horas" min="1"
                           value="<%= uf ? uf.horas : '' %>" required />
                </label>

                <% if (errores && errores.horas) { %>
                    <div class="error"><%= errores.horas %></div>
                <% } %>
            </div>

            <!-- Missatge general (si vols afegir-lo com al curs) -->
            <div id="UfMsg" class="form-msg form-full" aria-live="polite"></div>

            <!-- Botons -->
            <button type="submit" class="btn btn-primario btn-block form-full">
                <%= uf && uf.id ? "Guardar canvis" : "Crear UF" %>
            </button>

        </form>

    </div>
</div>

<script src="/js/ufs.js"></script>
