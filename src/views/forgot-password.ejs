<div class="login-container">
  <div class="login-card">
    <h1 class="login-title">Recuperar contrasenya</h1>
    <p class="login-subtitle">Introdueix el teu correu per rebre l’enllaç de recuperació</p>

    <form id="forgotPasswordForm" class="login-form" novalidate>
      <div class="form-group">
        <label for="forgotEmail">Correu electrònic</label>
        <input 
          type="email" 
          id="forgotEmail" 
          name="email" 
          placeholder="tu@cifo.com" 
          required
        >
      </div>

      <div id="forgotMsg" class="form-msg" aria-live="polite"></div>

      <button type="submit" class="btn btn-primario btn-block">
        Enviar enllaç de recuperació
      </button>
    </form>

    <p class="login-footer">
      Recordes la contrasenya? <a href="/login">Inicia sessió</a>
    </p>
  </div>
</div>
