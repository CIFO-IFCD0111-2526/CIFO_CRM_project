<h1>Professors</h1>

<% if (profesores && profesores.length > 0) { %>
  <ul>
    <% profesores.forEach(prof => { %>
      <li>
        <strong><%= prof.nombre %> <%= prof.apellidos %></strong> — <%= prof.email %>
        <% if (prof.Cursos && prof.Cursos.length > 0) { %>
          <br>
          <small>
            Cursos:
            <%= prof.Cursos.map(c => c.nombre).join(", ") %>
          </small>
        <% } else { %>
          <br><small>No imparteix cap curs.</small>
        <% } %>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <p>No hi ha professors registrats.</p>
<% } %>
