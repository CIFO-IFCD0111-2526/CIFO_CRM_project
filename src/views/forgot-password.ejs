<div class="login-container">
  <div class="login-card">
    <h1 class="login-title">Recuperar contrasenya</h1>
    <p class="login-subtitle login-subtitle--compact">Introdueix el teu correu per rebre l’enllaç de recuperació</p>

    <form id="forgotPasswordForm" class="login-form" novalidate>
      <div class="form-group">
        <label for="forgotPasswordEmail">Correu electrònic</label>
        <input
          type="email"
          id="forgotPasswordEmail"
          name="email"
          placeholder="tu@cifo.com"
          required
        >
      </div>

      <div id="forgotPasswordMsg" class="form-msg" aria-live="polite"></div>

      <button type="submit" class="btn btn-primario btn-block">
        Enviar enllaç de recuperació
      </button>
    </form>
  </div>
</div>
