<h1>Usuarios</h1>
<p style="color: #888;"><%= usuarios.length %> registros</p>

<% if (usuarios.length > 0) { %>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Nombre</th>
        <th>Email</th>
        <th>Nivel</th>
        <th>Activo</th>
      </tr>
    </thead>
    <tbody>
      <% usuarios.forEach(u => { %>
        <tr>
          <td><%= u.id %></td>
          <td><%= u.nombre %> <%= u.apellidos %></td>
          <td><%= u.email %></td>
          <td><%= u.nivel_acceso %></td>
          <td><%= u.activo ? 'Si' : 'No' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p>No hay usuarios registrados.</p>
<% } %>
