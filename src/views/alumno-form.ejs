<% var styles = '<link rel="stylesheet" href="../css/forms.css">' %>
<h1>Benvingut, <%= usuario.nombre %> <%= usuario.apellidos %></h1>
<h2>Nou Alumne</h2>

<form id="alumnoForm">
  <input name="nombre" placeholder="Nom" required />
  <input name="apellidos" placeholder="Cognoms" required />
  <input name="dni" placeholder="DNI" required />
  <input name="telefono" placeholder="Telèfon" />
  <input name="email" placeholder="Email" />
  <input name="nivel_estudios" placeholder="Nivell d'estudis" />

  <select name="tipo" required>
    <option value="">Selecciona tipus</option>
    <option value="actual">Actual</option>
    <option value="antiguo">Antic</option>
    <option value="futuro">Futur</option>
  </select>

  <label>
    <input type="checkbox" name="derechos_imagen" />
    Drets d'imagen
  </label>

  <label>
    <input type="checkbox" name="cesion_material" />
    Cesió material
  </label>

  <textarea name="comentarios" placeholder="Comentarios"></textarea>

  <button type="submit">Crear</button>
</form>

<script src="/js/alumnos.js"></script>