<div class="register-container">
  <div class="register-card">
    <h1 class="register-title">Registre</h1>
    <p class="register-subtitle">Crea un compte al CRM de CIFO La Violeta</p>

    <form id="registerForm" class="register-form" novalidate>
      <div class="form-group">
        <label for="registerNombre">Nom</label>
        <input type="text" id="registerNombre" name="nombre" placeholder="Nom" required>
      </div>
      <div class="form-group">
        <label for="registerApellidos">Cognoms</label>
        <input type="text" id="registerApellidos" name="apellidos" placeholder="Cognoms" required>
      </div>
      <div class="form-group">  
        <label for="registerEmail">Email</label>
        <input type="email" id="registerEmail" name="email" placeholder="tu@cifo.com" required>
      </div>

      <div class="form-group">
        <label for="registerPassword">Contrasenya</label>
        <input type="password" id="registerPassword" name="password" placeholder="••••••••" required>
      </div>
      <div class="form-group">  
        <label for="registerConfirmPassword">Confirmar contrasenya</label>
        <input type="password" id="registerConfirmPassword" name="confirmPassword" placeholder="••••••••" required>
      </div>

      <div id="registerMsg" class="form-msg" aria-live="polite"></div>

      <button type="submit" class="btn btn-primario btn-block">Registrar-se</button>
    </form>

    <p class="register-footer">
      Ja tens compte? <a href="/login">Inicia sessió</a>
    </p>
  </div>
</div>
